{
  "name": "skycrop-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:auth": "npm run dev --workspace=apps/auth",
    "dev:backend": "npm run dev --prefix backend",
    "build:web": "npm run build --workspace=apps/web",
    "build:auth": "npm run build --workspace=apps/auth",
    "build:all": "npm run build --workspaces",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  },
  "lint-staged": {
    "backend/src/**/*.js": [
      "prettier --write"
    ]
  }
}
